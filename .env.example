# ───────────────────────────────────────────────────────────────────────────
# DeskChalk configuration. Copy to .env and fill in. NEVER commit .env.
#   cp .env.example .env
# Minimum to get coaching: a FACEIT key + nickname, and one AI provider below.
# ───────────────────────────────────────────────────────────────────────────

# ── AI provider (bring your own) ───────────────────────────────────────────
# Pick one:
#   anthropic           Claude (best quality)
#   ollama              local, free, private
#   openai              OpenAI (gpt-4o, etc.)
#   gemini              Google Gemini
#   mistral             Mistral (EU)
#   groq                Groq (fast)
#   xai                 xAI / Grok
#   openai_compatible   any self-hosted OpenAI-compatible endpoint (vLLM, LM Studio, LocalAI)
# Note: Chinese AI providers (DeepSeek, Qwen, GLM, Kimi, etc.) are intentionally NOT supported.
LLM_PROVIDER=anthropic

# Anthropic / Claude — get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Model + thinking effort (low|medium|high). Leave default unless you have a reason.
CLAUDE_MODEL=claude-opus-4-8
CLAUDE_EFFORT=medium

# OpenAI-compatible providers (openai / gemini / mistral / groq / xai / openai_compatible).
# Set the key here OR via the provider's own var (OPENAI_API_KEY, GEMINI_API_KEY, …).
LLM_API_KEY=
# Override the model (each provider has a sensible default, e.g. openai→gpt-4o).
# LLM_MODEL=gpt-4o

# Base URL — REQUIRED for "ollama" and "openai_compatible"; optional override for the rest.
#   ollama (host from Docker): http://host.docker.internal:11434
#   openai_compatible:         http://your-endpoint:port/v1
LLM_BASE_URL=http://host.docker.internal:11434
# LLM_MODEL=llama3.1   # for ollama

# ── Database (bundled Postgres — leave as-is for the self-contained stack) ──
POSTGRES_DB=cs2
POSTGRES_USER=cs2
POSTGRES_PASSWORD=change-me
DB_DSN=postgresql://cs2:change-me@db:5432/cs2

# ── Web UI ──────────────────────────────────────────────────────────────────
APP_PORT=5608

# ── Data source 1: FACEIT stats (lowest friction, no demos) ─────────────────
# Key: https://developers.faceit.com/ → Apps → server-side API key. Leave blank to disable.
FACEIT_API_KEY=
FACEIT_NICKNAME=

# ── Data source 2: Steam matchmaking (optional, needs the `demos` profile) ──
# Polling uses your MAIN account via the Steam Web API (no login).
STEAM_API_KEY=
STEAM_ID64=
MATCH_AUTH_CODE=
SEED_SHARECODE=
# The GC client logs in with a DEDICATED bot account (never your main).
STEAM_USERNAME=
STEAM_PASSWORD=

# ── Tuning ──────────────────────────────────────────────────────────────────
POLL_SECONDS=300
WORKER_INTERVAL=60
# Demos older than this are auto-pruned from /demos. 0 = keep forever.
DEMO_RETENTION_DAYS=14

# Optional: Discord webhook for session recaps. Leave blank to disable.
DISCORD_WEBHOOK_URL=

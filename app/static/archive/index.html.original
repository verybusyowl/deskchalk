<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>CS2 · Analytics</title>
<link rel="stylesheet" href="/static/style.css">
</head>
<body>

<nav class="nav">
  <div class="logo">CS2 <em>·</em> Analytics</div>
  <div class="nav-sep"></div>
  <div class="nav-right">
    <label>Side</label>
    <select id="s-side"><option value="all">All</option><option value="CT">CT</option><option value="T">T</option></select>
    <label>Days</label>
    <select id="s-days">
      <option value="30">30d</option><option value="60">60d</option>
      <option value="90" selected>90d</option><option value="180">180d</option>
    </select>
    <div class="theme-picker-wrap" id="themePickerWrap">
      <button class="theme-btn" id="themeBtn" onclick="toggleThemePicker()" title="Change theme">
        <span class="theme-btn-dot" id="themeBtnDot"></span>
        Theme
      </button>
      <div class="theme-picker" id="themePicker"></div>
    </div>
    <a class="coach-btn" id="nav-coach" href="/coach" target="_blank">Full Coach ↗</a>
  </div>
</nav>

<div class="tabs-bar" id="tabs-bar">
  <button class="tab active" data-tab="overview" onclick="switchTab('overview')">Overview</button>
  <button class="tab" data-tab="replay" onclick="switchTab('replay')">&#9654; Replay</button>
</div>

<div class="main">

  <!-- ══ OVERVIEW ══ -->
  <div id="v-overview" class="view active">

    <div class="coach-panel" id="coach-overview">
      <div class="coach-hdr" onclick="toggleCoach('overview')">
        <span class="coach-label">AI Coach</span>
        <span class="coach-question" id="coach-q-overview"></span>
        <span class="coach-ts" id="coach-ts-overview"></span>
        <button class="coach-refresh" onclick="event.stopPropagation();refreshCoach('overview')">↻ Refresh</button>
        <span class="coach-caret"></span>
      </div>
      <div class="coach-body">
        <div id="coach-body-overview"><div class="spin">Loading coach brief…</div></div>
        <div class="coach-reminders-divider">Consistency Reminders</div>
        <div id="d-pit-wrap"></div>
      </div>
    </div>

    <div class="sec">Today's Session</div>
    <div class="grid col3 mb" id="session-row">
      <div class="stat-mini"><h4>Matches Today</h4><div class="spin" style="padding:6px">—</div></div>
      <div class="stat-mini"><h4>Today ADR</h4><div class="spin" style="padding:6px">—</div></div>
      <div class="stat-mini"><h4>Today K/D</h4><div class="spin" style="padding:6px">—</div></div>
    </div>

    <div class="sec">Performance</div>
    <div class="kpis mb" id="kpis">
      <div class="kpi"><div class="val">—</div><div class="lbl">Match Score</div></div>
      <div class="kpi"><div class="val">—</div><div class="lbl">Win %</div></div>
      <div class="kpi"><div class="val">—</div><div class="lbl">K / D</div></div>
      <div class="kpi"><div class="val">—</div><div class="lbl">ADR</div></div>
      <div class="kpi"><div class="val">—</div><div class="lbl">HS %</div></div>
      <div class="kpi"><div class="val">—</div><div class="lbl">Accuracy</div></div>
    </div>

    <div class="grid col2l mb">
      <div class="panel"><h3>Recent Form</h3><div id="d-form"><div class="spin">Loading…</div></div></div>
      <div class="panel"><h3>KPI Trend</h3><div id="d-trend"><div class="spin">Loading…</div></div></div>
    </div>

    <div class="grid col2 mb">
      <div class="panel">
        <h3>Performance Rating <span style="font-size:9px;color:var(--mu);font-weight:400">(synthetic — Valve doesn't expose CS2 rank via API)</span></h3>
        <div id="d-rating"><div class="spin">Loading…</div></div>
      </div>
      <div class="panel"><h3>Maps — Best to Worst</h3><div id="d-maps"><div class="spin">Loading…</div></div></div>
    </div>

    <div class="sec">Platform Comparison <span style="font-size:9px;color:var(--mu);font-weight:400">— Matchmaking vs FACEIT, separate data sets</span></div>
    <div class="platform-grid mb">
      <div class="platform-panel">
        <div class="platform-hdr">
          <span class="plat-pill mm">Matchmaking</span>
          <span class="plat-sub" id="mm-plat-sub"></span>
        </div>
        <div class="plat-kpis" id="plat-kpis-mm"></div>
        <div id="plat-maps-mm"></div>
      </div>
      <div class="platform-panel">
        <div class="platform-hdr">
          <span class="plat-pill faceit">FACEIT</span>
          <span class="plat-sub" id="faceit-plat-sub"></span>
        </div>
        <div id="faceit-panel-content"><div class="spin">Loading…</div></div>
      </div>
    </div>

    <div class="sec">Weapons &amp; History</div>
    <div class="panel mb"><h3>Top Weapons</h3><div id="d-wpn"><div class="spin">Loading…</div></div></div>

  </div>

  <!-- ══ MAP VIEW ══ -->
  <div id="v-map" class="view">

    <div class="map-header">
      <div class="map-title" id="map-title">—</div>
      <div class="map-actions">
        <button class="icon-btn on" id="aim-btn" onclick="toggleAim()">Kills</button>
        <button class="icon-btn" id="pro-btn" onclick="togglePro()">Pro: Off</button>
        <a class="coach-btn" id="map-coach-link" href="/coach" target="_blank">Full Coach ↗</a>
      </div>
    </div>

    <div id="m-warn" class="warn-banner" style="display:none"></div>
    <div id="m-verdict"></div>
    <div class="coaching-bar" id="m-coaching-bar">
      <span class="cb-icon">&#128161;</span>
      <span class="cb-text" id="cbText"></span>
      <button class="cb-dismiss" onclick="$('m-coaching-bar').style.display='none'" title="Dismiss">&#215;</button>
    </div>

    <!-- ── SECTION PILL NAV (sticky) ── -->
    <nav class="map-pill-nav" id="mapPillNav" aria-label="Map sections">
      <button class="map-pill active" data-sec="msp-overview"  onclick="scrollToSection('msp-overview')">Overview</button>
      <button class="map-pill"        data-sec="msp-positions" onclick="scrollToSection('msp-positions')">Positions</button>
      <button class="map-pill"        data-sec="msp-analysis"  onclick="scrollToSection('msp-analysis')">Analysis</button>
      <button class="map-pill"        data-sec="msp-history"   onclick="scrollToSection('msp-history')">History</button>
    </nav>

    <!-- ══ OVERVIEW (merged stats) ══ -->
    <div class="map-section" id="msp-overview">
      <div class="panel mb" id="m-playstyle"><div class="spin">Loading…</div></div>
      <div class="map-kpis mb" id="m-kpis">
        <div class="kpi"><div class="val">—</div><div class="lbl">Matches</div></div>
        <div class="kpi"><div class="val">—</div><div class="lbl">Win %</div></div>
        <div class="kpi"><div class="val">—</div><div class="lbl">K / D</div></div>
        <div class="kpi"><div class="val">—</div><div class="lbl">ADR</div></div>
        <div class="kpi"><div class="val">—</div><div class="lbl">Opening Win %</div></div>
      </div>
      <div class="grid col2 mb">
        <div class="panel" id="m-consistency"><div class="spin">Loading…</div></div>
        <div class="panel"><h3>Top Weapons</h3><div id="m-wpn"><div class="spin">Loading…</div></div></div>
      </div>
      <div class="side-cards mb" id="m-sides">
        <div class="side-card ct"><h3>CT SIDE</h3><div class="spin">Loading…</div></div>
        <div class="side-card t"><h3>T SIDE</h3><div class="spin">Loading…</div></div>
      </div>
      <div class="grid col2 mb">
        <div class="stat-mini" id="m-economy"><h4>Economy</h4><div class="spin" style="padding:4px">—</div></div>
        <div class="stat-mini" id="m-clutch"><h4>Clutch Situations</h4><div class="spin" style="padding:4px">—</div></div>
      </div>
      <details class="analysis-details mb">
        <summary>Phase Breakdown</summary>
        <div class="panel-inner" id="m-phase"><div class="spin">Loading…</div></div>
      </details>
    </div>

    <!-- ══ POSITIONS + GRENADES ══ -->
    <div class="map-section" id="msp-positions">
      <div class="pos-sub-nav">
        <button class="pos-tab active" data-ptab="kills"    onclick="switchPosTab('kills')">Kills &amp; Deaths</button>
        <button class="pos-tab"        data-ptab="aim"      onclick="switchPosTab('aim')">Aim &amp; Damage</button>
        <button class="pos-tab"        data-ptab="grenades" onclick="switchPosTab('grenades')">Grenades</button>
      </div>

      <!-- Kills & Deaths -->
      <div class="pos-panel active" id="pp-kills">
        <div class="grid col2 mb">
          <div class="img-panel">
            <h3 id="t-kills">Kill Locations</h3>
            <div class="img-controls">
              <span style="color:var(--mu);font-size:10px" id="density-legend">Density = &gt;30d history</span>
              <span><i class="dot" style="background:#3cdc5a"></i> <span id="kill-legend-label">Last 30d</span></span>
              <span id="hs-legend" style="display:none"><i class="dot" style="background:#d47020"></i> Body</span>
              <span id="pro-legend" style="display:none"><i class="dot" style="background:#5090ff;opacity:.6"></i> Pro</span>
              <span class="aim-weapon-wrap" id="aim-weapon-wrap">
                <select class="aim-weapon-sel" id="aim-weapon-sel" onchange="refreshMapImages()" title="Filter by weapon">
                  <option value="">All weapons</option>
                  <option value="AK-47">AK-47</option><option value="M4A4">M4A4</option>
                  <option value="M4A1-S">M4A1-S</option><option value="AWP">AWP</option>
                  <option value="USP-S">USP-S</option><option value="Glock-18">Glock-18</option>
                  <option value="Desert Eagle">Deagle</option><option value="SG 553">SG 553</option>
                  <option value="AUG">AUG</option><option value="FAMAS">FAMAS</option>
                  <option value="Galil AR">Galil AR</option><option value="SSG 08">Scout</option>
                </select>
              </span>
            </div>
            <img id="i-kills" src="" alt="">
          </div>
          <div class="img-panel">
            <h3>Death Locations <span style="font-size:9px;color:var(--mu);font-weight:400">— CT blue / T orange / gold=HS</span> <span id="predict-badge" class="predict-badge"></span></h3>
            <div class="img-controls">
              <span style="color:var(--mu);font-size:10px">Density = &gt;30d history</span>
              <span><i class="dot" style="background:#f04040"></i> Last 30d</span>
              <span id="pro-legend-d" style="display:none"><i class="dot" style="background:#5090ff;opacity:.6"></i> Pro</span>
            </div>
            <div class="death-map-wrap">
              <img id="i-deaths" src="" alt="" onload="renderDeathDots()">
              <canvas id="dp-canvas"></canvas>
            </div>
          </div>
        </div>
      </div>

      <!-- Aim & Damage -->
      <div class="pos-panel" id="pp-aim">
        <div class="grid col2 mb">
          <div class="img-panel"><h3>Damage You Take</h3><img id="i-hbin" src="" alt=""></div>
          <div class="img-panel"><h3>Damage You Deal</h3><img id="i-hbout" src="" alt=""></div>
        </div>
      </div>

      <!-- Grenades -->
      <div class="pos-panel" id="pp-grenades">
        <div class="grid col2 mb">
          <div class="img-panel" id="g-heatmap-panel">
            <h3>Grenade Patterns &amp; Trajectories</h3>
            <div class="img-controls" style="flex-wrap:wrap">
              <div class="g-pills" style="margin:0">
                <button class="g-pill on-all" data-gt="" onclick="setGrenadeFilter(this,'')">All</button>
                <button class="g-pill" data-gt="smoke" onclick="setGrenadeFilter(this,'smoke')">Smoke</button>
                <button class="g-pill" data-gt="flash" onclick="setGrenadeFilter(this,'flash')">Flash</button>
                <button class="g-pill" data-gt="molotov" onclick="setGrenadeFilter(this,'molotov')">Molotov</button>
                <button class="g-pill" data-gt="he" onclick="setGrenadeFilter(this,'he')">HE</button>
              </div>
            </div>
            <div class="img-legend" style="padding:2px 10px 5px">
              <span style="color:var(--mu)">Glow = &gt;30d density</span>
              <span>→ throw path</span>
              <span><i class="dot" style="background:#ddd"></i>Smoke</span>
              <span><i class="dot" style="background:#d4c040"></i>Flash</span>
              <span><i class="dot" style="background:#d47020"></i>Molotov</span>
              <span><i class="dot" style="background:#c44040"></i>HE</span>
            </div>
            <img id="i-gren" src="" alt="">
          </div>
          <div class="panel">
            <h3>Lineup Reference</h3>
            <div class="g-pills" id="ref-pills">
              <button class="g-pill on-all" data-gt="" onclick="filterLineups('')">All</button>
              <button class="g-pill" data-gt="smoke" onclick="filterLineups('smoke')">Smoke</button>
              <button class="g-pill" data-gt="flash" onclick="filterLineups('flash')">Flash</button>
              <button class="g-pill" data-gt="molotov" onclick="filterLineups('molotov')">Molotov</button>
              <button class="g-pill" data-gt="he" onclick="filterLineups('he')">HE</button>
            </div>
            <div id="m-lineups"><div class="spin">Loading…</div></div>
          </div>
        </div>
        <div class="panel mb" id="m-flash"><div class="spin">Loading…</div></div>
        <div class="grid col2 mb">
          <div class="img-panel">
            <h3>Smoke Coverage <span style="font-size:9px;color:var(--mu);font-weight:400">— landing positions</span></h3>
            <div class="img-legend" style="padding:2px 10px 5px"><span><i class="dot" style="background:#ddd"></i>Each dot = one smoke</span></div>
            <img id="i-smokes" src="" alt="">
          </div>
          <div class="img-panel">
            <h3>Flash Coverage <span style="font-size:9px;color:var(--mu);font-weight:400">— landing positions</span></h3>
            <div class="img-legend" style="padding:2px 10px 5px"><span><i class="dot" style="background:#d4c040"></i>Each dot = one flash</span></div>
            <img id="i-flashes" src="" alt="">
          </div>
        </div>
      </div>
    </div>

    <!-- ══ ANALYSIS ══ -->
    <div class="map-section" id="msp-analysis">
      <!-- Combat row: 3 cards side by side -->
      <div class="grid col3 mb">
        <div class="panel">
          <h3>Opening Duels</h3>
          <div id="m-opening-duel"><div class="spin">Loading…</div></div>
        </div>
        <div class="panel">
          <h3>Trade Discipline</h3>
          <div id="m-trade-disc"><div class="spin">Loading…</div></div>
        </div>
        <div class="panel">
          <h3>Clutch Profile</h3>
          <div id="m-clutch-profile"><div class="spin">Loading…</div></div>
        </div>
      </div>
      <!-- Economy + Aim -->
      <div class="panel mb">
        <h3>Economy Advisor</h3>
        <div id="m-econ-advisor"><div class="spin">Loading…</div></div>
      </div>
      <div class="panel mb">
        <h3>Aim Profile <span style="font-size:9px;color:var(--mu);font-weight:400;margin-left:4px">crosshair placement by distance</span></h3>
        <div id="m-aim-profile"><div class="spin">Loading…</div></div>
      </div>
      <!-- Deep-dive accordions -->
      <details class="analysis-details mb">
        <summary>Duel Breakdown</summary>
        <div class="panel-inner" id="m-duel"><div class="spin">Loading…</div></div>
      </details>
      <details class="analysis-details mb">
        <summary>Utility Tendencies</summary>
        <div class="panel-inner">
          <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:8px">
            <label style="font-size:10px;color:var(--mu)">Side:</label>
            <select id="utSide" style="font-size:10px;background:var(--sf2);border:1px solid var(--bd2);color:var(--tx);padding:2px 5px;border-radius:3px" onchange="rpLoadUtilTend()">
              <option value="all">Both</option><option value="CT">CT</option><option value="T">T</option>
            </select>
            <label style="font-size:10px;color:var(--mu)">Nade:</label>
            <select id="utNade" style="font-size:10px;background:var(--sf2);border:1px solid var(--bd2);color:var(--tx);padding:2px 5px;border-radius:3px" onchange="rpLoadUtilTend()">
              <option value="all">All</option><option value="smoke">Smoke</option>
              <option value="flash">Flash</option><option value="molotov">Molotov</option>
              <option value="he">HE</option>
            </select>
          </div>
          <div id="utBody"><div class="spin">Select a match first.</div></div>
        </div>
      </details>
      <details class="analysis-details mb">
        <summary>Training Drills</summary>
        <div class="panel-inner">
          <div style="display:flex;gap:10px;align-items:center;margin-bottom:8px">
            <button class="btn" onclick="this.closest('details').open=true;loadDrills()">Get AI Drill Recommendations</button>
            <span style="font-size:11px;color:var(--mu)" id="drills-status"></span>
          </div>
          <div id="drills-body"></div>
        </div>
      </details>
    </div>

    <!-- ══ HISTORY ══ -->
    <div class="map-section" id="msp-history">
      <div class="map-sec-hdr">History</div>
      <div class="sec">Coaching</div>
      <div class="panel mb"><div id="m-pit"><div class="spin">Loading…</div></div></div>
      <div class="coach-panel collapsed mb" id="coach-map">
        <div class="coach-hdr" onclick="toggleCoach('map')">
          <span class="coach-label">AI Coach</span>
          <span class="coach-question" id="coach-q-map"></span>
          <span class="coach-ts" id="coach-ts-map"></span>
          <button class="coach-refresh" onclick="event.stopPropagation();refreshCoach('map')">↻ Refresh</button>
          <span class="coach-caret"></span>
        </div>
        <div class="coach-body" id="coach-body-map"><div class="spin">Loading coach brief…</div></div>
      </div>
      <div class="sec">Match History</div>
      <div class="grid col2l mb">
        <div class="panel">
          <h3>Recent Matches — click to analyse</h3>
          <div id="m-form"><div class="spin">Loading…</div></div>
        </div>
        <div class="panel"><h3>Score Trend</h3><div id="m-trend"><div class="spin">Loading…</div></div></div>
      </div>
    </div>

  </div><!-- /v-map -->

  <!-- ══ REPLAY TAB ══ -->
  <div class="view" id="v-replay">
    <div class="rp-layout">
      <!-- sidebar -->
      <div class="rp-sidebar">
        <div class="rp-sidebar-hdr">
          <button class="rp-back-btn" id="rpBackBtn" onclick="rpBackToMatches()" style="display:none">&#8592; Back</button>
          <span class="rp-sidebar-hdr-title" id="rpSidebarTitle">Matches</span>
        </div>
        <div class="rp-filter-bar" id="rpFilterBar" style="display:none">
          <button class="rp-chip active" id="rpChipAll"    onclick="rpSetFilter('all')">All</button>
          <button class="rp-chip" id="rpChipCT"    onclick="rpSetFilter('CT')">CT</button>
          <button class="rp-chip" id="rpChipT"     onclick="rpSetFilter('T')">T</button>
          <button class="rp-chip" id="rpChipWon"   onclick="rpSetFilter('won')">Won</button>
          <button class="rp-chip" id="rpChipLost"  onclick="rpSetFilter('lost')">Lost</button>
          <button class="rp-chip" id="rpChipEco"   onclick="rpSetFilter('eco')">Eco</button>
          <button class="rp-chip" id="rpChipForce" onclick="rpSetFilter('force')">Force</button>
          <button class="rp-chip" id="rpChipFull"  onclick="rpSetFilter('full')">Full</button>
          <button class="rp-chip" id="rpChipClutch" onclick="rpToggleChip('clutch')">Clutch</button>
          <button class="rp-chip" id="rpChipFK"    onclick="rpToggleChip('opening')">FK</button>
        </div>
        <div class="rp-sidebar-list" id="rpSidebarList">
          <div class="spin">Loading&#8230;</div>
        </div>
      </div>
      <!-- main -->
      <div class="rp-main">
        <div class="rp-infobar" id="rpInfobar">
          <span class="rp-infobar-map" id="rpMapLabel">&#8212;</span>
          <span class="rp-infobar-score" id="rpScoreLabel"></span>
          <span class="rp-infobar-date" id="rpDateLabel"></span>
          <div class="rp-infobar-right" id="rpInfoRight">
            <button class="rp-pattern-btn" id="rpPatternBtn" onclick="rpTogglePatterns()">&#128202; Patterns</button>
            <button class="rp-pattern-btn" id="rpAllMatchBtn" onclick="rpToggleAllMatches()" title="Overlay all-match kill positions">&#127760; All Matches</button>
            <button class="rp-pattern-btn" id="rpExportBtn" onclick="rpExportPNG()" title="Export summary PNG">&#10515; Export</button>
            <button class="rp-pattern-btn" id="rpReviewBtn" onclick="rpOpenReview()" title="AI storyboard review of this round">&#127916; Review</button>

            <button class="icon-btn rp-fs-btn" id="rpFsBtn" onclick="rpToggleFullscreen()" title="Fullscreen (F)">&#x26F6;</button>
          </div>
        </div>

        <div class="rp-canvas-area">
          <div class="rp-round-nav">
            <button class="icon-btn" onclick="rpPrevRound()">&#8249;</button>
            <span class="rp-round-nav-label" id="rpRoundLabel">&#8212;</span>
            <button class="icon-btn" onclick="rpNextRound()">&#8250;</button>
            <div class="rp-legend">
              <span class="rp-legend-ct">&#9679; CT</span>
              <span class="rp-legend-t">&#9679; T</span>
              <span class="rp-legend-me">&#9711; You</span>
              <span class="rp-legend-dead">&#10005; Dead</span>
            </div>
          </div>
          <div class="rp-layer-bar" id="rpLayerBar">
            <span style="font-size:10px;color:var(--mu);margin-right:2px">Layers:</span>
            <button class="rp-layer-btn" data-layer="routes"    onclick="rpToggleLayer('routes')">Routes</button>
            <button class="rp-layer-btn" data-layer="utility"   onclick="rpToggleLayer('utility')">Utility</button>
            <button class="rp-layer-btn" data-layer="nadepaths" onclick="rpToggleLayer('nadepaths')">Nade Paths</button>
            <button class="rp-layer-btn" data-layer="contact"   onclick="rpToggleLayer('contact')">1st Contact</button>
            <button class="rp-layer-btn" data-layer="danger"    onclick="rpToggleLayer('danger')">Danger Zones</button>
            <button class="rp-layer-btn" data-layer="allroutes" onclick="rpToggleLayer('allroutes')">All Rounds</button>
          </div>
          <div class="rp-canvas-mid">
            <div class="rp-team-panel rp-ct-panel" id="rpCtPanel">
              <div class="rp-tp-hdr">Counter-Terrorist</div>
            </div>
            <div class="rp-canvas-wrap" id="rpCanvasWrap">
              <canvas id="rpCanvas"></canvas>
              <div class="rp-no-data" id="rpNoData">Select a match and round</div>
            </div>
            <div class="rp-team-panel rp-t-panel" id="rpTPanel">
              <div class="rp-tp-hdr">Terrorist</div>
            </div>
          </div>
          <div class="rp-controls">
            <button id="rpPlayBtn" class="icon-btn" onclick="rpTogglePlay()">&#9654; Play</button>
            <select id="rpSpeedSel" onchange="rpSetSpeed(this.value)">
              <option value="0.5">0.5&#215;</option>
              <option value="1" selected>1&#215;</option>
              <option value="2">2&#215;</option>
              <option value="4">4&#215;</option>
            </select>
            <div class="rp-scrub-wrap">
              <canvas id="rpScrubMarkers" height="10"></canvas>
              <input type="range" id="rpScrubber" min="0" max="100" value="0" oninput="rpScrub(this.value)">
            </div>
            <span class="rp-time-lbl" id="rpTimeLabel">0:00</span>
          </div>
        </div>
        <div class="rp-bottom-row">
          <div id="rpKillFeedPanel" style="display:none">
            <div class="rp-panel-hdr">Round Events</div>
            <div id="rpKillFeedList"></div>
          </div>
          <div id="rpAimPanel" style="display:none">
            <div class="rp-panel-hdr" style="width:100%;text-align:center">Aim</div>
            <canvas id="rpAimCanvas" width="120" height="180"></canvas>
            <div class="rp-aim-stat" id="rpAimStat">Aim: — HS</div>
          </div>
        </div>
        <div class="rp-narrative" id="rpNarrative">Select a round to see the match narrative.</div>
        <div class="rp-storyboard" id="rpStoryboard" style="display:none">
          <div class="rp-sb-hdr">
            <span>Round Storyboard</span>
            <button class="rp-sb-close" onclick="rpCloseReview()">&#10005;</button>
          </div>
          <div class="rp-sb-strip" id="rpSbStrip"></div>
        </div>
        <div class="rp-coach-area" id="rpCoachArea">
          <div class="rp-coach-hdr" onclick="rpToggleCoach()">
            <span class="coach-label">Coach</span>
            <span id="rpCoachQ" style="font-size:10px;color:var(--mu);flex:1;
              overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
              Ask about the current round&#8230;
            </span>
            <span id="rpCoachCaret" style="font-size:10px;color:var(--mu)">&#9656;</span>
          </div>
          <div class="rp-coach-body">
            <div class="rp-coach-row">
              <input type="text" id="rpCoachInput" placeholder="Ask about this round&#8230;">
              <button class="icon-btn" onclick="rpAskCoach()">Ask</button>
            </div>
            <div id="rpCoachAnswer" class="rp-coach-answer"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

</div><!-- /main -->

<!-- ══ match detail modal ══ -->
<div class="modal-bg hidden" id="match-modal" onclick="if(event.target===this)closeModal()">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">×</button>
    <div class="modal-hdr">
      <div class="modal-title" id="md-title">Match Detail</div>
      <div class="modal-sub" id="md-sub"></div>
    </div>
    <!-- inner tab bar -->
    <div class="modal-tabs">
      <button class="modal-tab active" onclick="switchModalTab('stats')">Stats</button>
      <button class="modal-tab" onclick="switchModalTab('rounds')">Rounds</button>
      <button class="modal-tab" onclick="switchModalTab('kills')">Kills</button>
      <button class="modal-tab" onclick="switchModalTab('economy')">Economy</button>

    </div>
    <!-- Stats panel -->
    <div class="modal-panel active" id="mp-stats">
      <div class="grid col2 mb">
        <div>
          <h3 style="font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--mu2);margin-bottom:8px">Your Stats vs Your Average</h3>
          <div id="md-vs"></div>
        </div>
        <div>
          <h3 style="font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--mu2);margin-bottom:6px">CT / T Split</h3>
          <div id="md-sides"></div>
        </div>
      </div>
    </div>
    <!-- Rounds panel -->
    <div class="modal-panel" id="mp-rounds">
      <div class="mb">
        <h3 style="font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--mu2);margin-bottom:4px">Round Timeline</h3>
        <div class="round-timeline" id="md-rounds"></div>
      </div>
    </div>
    <!-- Kills panel -->
    <div class="modal-panel" id="mp-kills">
      <div>
        <h3 style="font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--mu2);margin-bottom:6px">Kill Breakdown</h3>
        <div id="md-kills"></div>
      </div>
    </div>
    <!-- Economy panel -->
    <div class="modal-panel" id="mp-economy">
      <div>
        <h3 style="font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--mu2);margin-bottom:6px">Economy Breakdown</h3>
        <div id="md-econ"></div>
      </div>
    </div>

  </div>
</div>

<script src="/static/app.js"></script>
</body>
</html>

{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/coach/**",
              "components/core/**",
              "components/data/**",
              "components/identity/**",
              "components/navigation/**",
              "ui_kits/owl-coach/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Chakra Petch|Barlow|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Chakra Petch, Barlow, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|shape|ring|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, shape, ring, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:rounded|circle)$/]",
        "message": "<Avatar> shape must be one of 'rounded' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='ring'] > Literal[value!=/^(?:none|mint|orange|neutral)$/]",
        "message": "<Avatar> ring must be one of 'none' | 'mint' | 'orange' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|size|icon|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, variant, size, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|good|bad|warn|info)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'good' | 'bad' | 'warn' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid|outline)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BaselineProgress'] > JSXAttribute > JSXIdentifier[name!=/^(?:baseline|current|target|unit|goodDirection|label|height|style|key|ref|className|style|children)$/]",
        "message": "<BaselineProgress> doesn't accept that prop. Declared props: baseline, current, target, unit, goodDirection, label, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BaselineProgress'] > JSXAttribute[name.name='goodDirection'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<BaselineProgress> goodDirection must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|iconLeft|iconRight|fullWidth|disabled|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, iconLeft, iconRight, fullWidth, disabled, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|accent|padding|interactive|as|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, accent, padding, interactive, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:none|mint|orange|neutral)$/]",
        "message": "<Card> accent must be one of 'none' | 'mint' | 'orange' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EloRing'] > JSXAttribute > JSXIdentifier[name!=/^(?:elo|progress|size|level|animate|style|key|ref|className|style|children)$/]",
        "message": "<EloRing> doesn't accept that prop. Declared props: elo, progress, size, level, animate, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|message|action|compact|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: icon, title, message, action, compact, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FocusSupportingStat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<FocusSupportingStat> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='InsightCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:rank|kind|title|detail|metric|delta|goodDirection|style|key|ref|className|style|children)$/]",
        "message": "<InsightCard> doesn't accept that prop. Declared props: rank, kind, title, detail, metric, delta, goodDirection, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='InsightCard'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:fix|strength)$/]",
        "message": "<InsightCard> kind must be one of 'fix' | 'strength'."
      },
      {
        "selector": "JSXOpeningElement[name.name='InsightCard'] > JSXAttribute[name.name='goodDirection'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<InsightCard> goodDirection must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LevelBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:level|size|showLabel|style|key|ref|className|style|children)$/]",
        "message": "<LevelBadge> doesn't accept that prop. Declared props: level, size, showLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LevelBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<LevelBadge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapPills'] > JSXAttribute > JSXIdentifier[name!=/^(?:maps|value|winRates|onChange|style|key|ref|className|style|children)$/]",
        "message": "<MapPills> doesn't accept that prop. Declared props: maps, value, winRates, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute > JSXIdentifier[name!=/^(?:data|width|height|tone|fill|dot|strokeWidth|style|key|ref|className|style|children)$/]",
        "message": "<Sparkline> doesn't accept that prop. Declared props: data, width, height, tone, fill, dot, strokeWidth, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sparkline'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|good|bad|info)$/]",
        "message": "<Sparkline> tone must be one of 'neutral' | 'good' | 'bad' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|delta|goodDirection|spark|emphasis|style|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, unit, delta, goodDirection, spark, emphasis, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='goodDirection'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<StatCard> goodDirection must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='emphasis'] > Literal[value!=/^(?:normal|hero)$/]",
        "message": "<StatCard> emphasis must be one of 'normal' | 'hero'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrendIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:delta|goodDirection|unit|size|showArrow|style|key|ref|className|style|children)$/]",
        "message": "<TrendIndicator> doesn't accept that prop. Declared props: delta, goodDirection, unit, size, showArrow, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrendIndicator'] > JSXAttribute[name.name='goodDirection'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<TrendIndicator> goodDirection must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TrendIndicator'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<TrendIndicator> size must be one of 'sm' | 'md' | 'lg'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
